# Email IMAP Configuration
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

# Sender blacklist (comma-separated, case-insensitive partial match)
EMAIL_SENDER_BLACKLIST=noreply,no-reply,mailer-daemon

# AI Configuration (Ollama = local, free)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI API (optional cloud fallback)
# OPENAI_API_KEY=sk-your-key-here

# RSS Feeds (comma-separated)
RSS_FEEDS=https://hnrss.org/frontpage,https://feeds.feedburner.com/TechCrunch

# Output
OUTPUT_DIR=output
MAX_ARTICLES=20
